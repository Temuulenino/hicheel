@model IEnumerable<CompanyMVC.Models.Salbar>
@{ ViewData["Title"] = "Салбарын жагсаалт"; }

<h2 class="mb-3">🏢 Салбарын жагсаалт</h2>
<a asp-action="Create" class="btn btn-primary mb-3">+ Шинэ салбар нэмэх</a>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>№</th>
            <th>Нэр</th>
            <th>Хаяг</th>
            <th>Утас</th>
            <th>Үйлдэл</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.SalbarId</td>
                <td>@item.Ner</td>
                <td>@item.Hayg</td>
                <td>@item.Utasny_dugaar</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.SalbarId"
                       class="btn btn-warning btn-sm">✏️ Засах</a>
                    <a asp-action="Delete" asp-route-id="@item.SalbarId"
                       class="btn btn-danger btn-sm">🗑️ Устгах</a>
                </td>
            </tr>
        }
    </tbody>
</table>