@model week2.Models.Worker

<h2>Ажилтан устгах уу?</h2>

<div class="alert alert-danger">
    <p><strong>Ажилтны нэр:</strong> @Model.wname</p>
    <p><strong>Цалин:</strong> @Model.salary.ToString("N0")₮</p>
    <p><strong>Салбар:</strong> @Model.branch?.bname</p>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="ID" />
    <button type="submit" class="btn btn-danger">Устгах</button>
    <a asp-action="Index" class="btn btn-secondary">Буцах</a>
</form>