@model Company.Models.Branch
@{
    ViewData["Title"] = "Шинэ салбар";
}

<h1>Шинэ салбар нэмэх</h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group">
                <label class="control-label">Салбарын нэр</label>
                <input asp-for="Branchname" class="form-control" />
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Үүсгэх" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Буцах</a>
            </div>
        </form>
    </div>
</div>